generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subject {
  id             String          @id @default(cuid())
  name           String
  school         String?
  program        String?
  major          String?
  description    String?
  topics         Topic[]
  questionSets   QuestionSet[]
  studyMaterials StudyMaterial[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Topic {
  id             String          @id @default(cuid())
  subjectId      String
  name           String
  subject        Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questionSets   QuestionSet[]
  studyMaterials StudyMaterial[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([subjectId, name])
}

enum StudyMaterialType {
  pdf
  slides
  notes
  document
  link
  other
}

enum StudyMaterialSourceType {
  externalLink
  uploadedFile
}

enum StudyMaterialStatus {
  draft
  pendingReview
  published
  rejected
}

enum QuestionSetSourceType {
  system
  community
}

enum QuestionSetStatus {
  draft
  pendingReview
  published
  rejected
}

model StudyMaterial {
  id            String                  @id @default(cuid())
  subjectId     String
  topicId       String?
  title         String
  description   String
  materialType  StudyMaterialType
  sourceType    StudyMaterialSourceType
  sourceUrl     String?
  fileName      String?
  mimeType      String?
  fileSizeBytes Int?
  language      String?
  status        StudyMaterialStatus     @default(draft)
  subject       Subject                 @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic         Topic?                  @relation(fields: [topicId], references: [id], onDelete: SetNull)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([status, createdAt, id])
  @@index([subjectId, status, createdAt, id])
  @@index([topicId, status, createdAt, id])
  @@index([materialType, status, createdAt, id])
}

model QuestionSet {
  id              String                @id @default(cuid())
  subjectId       String
  topicId         String?
  title           String
  description     String
  status          QuestionSetStatus     @default(published)
  sourceType      QuestionSetSourceType @default(system)
  createdByUserId String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  publishedAt     DateTime?
  rejectionReason String?
  subject         Subject               @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic           Topic?                @relation(fields: [topicId], references: [id], onDelete: SetNull)
  questions       Question[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([status, createdAt, id])
  @@index([sourceType, status, createdAt, id])
  @@index([subjectId, status, createdAt, id])
  @@index([topicId, status, createdAt, id])
}

model Question {
  id            String         @id @default(cuid())
  questionSetId String
  text          String
  explanation   String?
  position      Int
  questionSet   QuestionSet    @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  answerOptions AnswerOption[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([questionSetId, position])
}

model AnswerOption {
  id         String   @id @default(cuid())
  questionId String
  text       String
  position   Int
  isCorrect  Boolean  @default(false)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([questionId, position])
}
