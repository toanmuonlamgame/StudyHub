generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subject {
  id             String          @id @default(cuid())
  name           String
  school         String?
  program        String?
  major          String?
  description    String?
  isArchived     Boolean         @default(false)
  topics         Topic[]
  questionSets   QuestionSet[]
  studyMaterials StudyMaterial[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([isArchived, name])
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  displayName  String
  passwordHash String
  role         UserRole      @default(user)
  status       UserStatus    @default(active)
  sessions     AuthSession[]
  bookmarks    Bookmark[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status, role, createdAt])
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  disabled
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model Topic {
  id             String          @id @default(cuid())
  subjectId      String
  name           String
  isArchived     Boolean         @default(false)
  subject        Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questionSets   QuestionSet[]
  studyMaterials StudyMaterial[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([subjectId, name])
  @@index([subjectId, isArchived, name])
}

enum StudyMaterialType {
  pdf
  slides
  notes
  document
  link
  other
}

enum StudyMaterialSourceType {
  externalLink
  uploadedFile
}

enum StudyMaterialStatus {
  draft
  pendingReview
  published
  rejected
}

enum QuestionSetSourceType {
  system
  community
}

enum QuestionSetStatus {
  draft
  pendingReview
  published
  rejected
}

model StudyMaterial {
  id            String                  @id @default(cuid())
  subjectId     String
  topicId       String?
  title         String
  description   String
  materialType  StudyMaterialType
  sourceType    StudyMaterialSourceType
  sourceUrl     String?
  fileName      String?
  mimeType      String?
  fileSizeBytes Int?
  language      String?
  status        StudyMaterialStatus     @default(draft)
  subject       Subject                 @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic         Topic?                  @relation(fields: [topicId], references: [id], onDelete: SetNull)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([status, createdAt, id])
  @@index([subjectId, status, createdAt, id])
  @@index([topicId, status, createdAt, id])
  @@index([materialType, status, createdAt, id])
}

model QuestionSet {
  id                    String                @id @default(cuid())
  subjectId             String
  topicId               String?
  title                 String
  description           String
  status                QuestionSetStatus     @default(published)
  sourceType            QuestionSetSourceType @default(system)
  createdByUserId       String?
  clientSubmissionId    String?               @unique
  submissionFingerprint String?
  submittedAt           DateTime?
  reviewedAt            DateTime?
  publishedAt           DateTime?
  rejectionReason       String?
  isArchived            Boolean               @default(false)
  reviewedByUserId      String?
  subject               Subject               @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic                 Topic?                @relation(fields: [topicId], references: [id], onDelete: SetNull)
  questions             Question[]
  examAttempts          ExamAttempt[]
  bookmarks             Bookmark[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([status, createdAt, id])
  @@index([sourceType, status, createdAt, id])
  @@index([subjectId, status, createdAt, id])
  @@index([topicId, status, createdAt, id])
  @@index([isArchived, status, createdAt, id])
}

model Bookmark {
  id            String      @id @default(cuid())
  userId        String
  questionSetId String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionSet   QuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([userId, questionSetId])
  @@index([userId, createdAt, id])
  @@index([questionSetId])
}

model ExamAttempt {
  id                  String              @id @default(cuid())
  userId              String
  submissionId        String
  requestFingerprint  String
  questionSetId       String
  sourceQuestionSetId String?
  questionSetTitle    String
  startedAt           DateTime?
  completedAt         DateTime            @default(now())
  totalQuestions      Int
  correctAnswers      Int
  wrongAnswers        Int
  unansweredAnswers   Int
  percentageScore     Float
  questionSet         QuestionSet?        @relation(fields: [sourceQuestionSetId], references: [id], onDelete: SetNull)
  answers             ExamAttemptAnswer[]
  createdAt           DateTime            @default(now())

  @@unique([userId, submissionId])
  @@index([userId, completedAt, id])
  @@index([sourceQuestionSetId])
}

model ExamAttemptAnswer {
  id                     String      @id @default(cuid())
  attemptId              String
  questionId             String
  questionText           String
  answerOptions          Json
  selectedAnswerOptionId String?
  selectedAnswerText     String?
  correctAnswerOptionId  String
  correctAnswerText      String
  isCorrect              Boolean
  explanation            String?
  questionMedia          Json?
  explanationMedia       Json?
  position               Int
  attempt                ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  createdAt              DateTime    @default(now())

  @@unique([attemptId, position])
  @@index([attemptId])
}

model Question {
  id               String         @id @default(cuid())
  questionSetId    String
  text             String
  explanation      String?
  media            Json?
  explanationMedia Json?
  position         Int
  questionSet      QuestionSet    @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  answerOptions    AnswerOption[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([questionSetId, position])
}

model AnswerOption {
  id         String   @id @default(cuid())
  questionId String
  text       String
  position   Int
  isCorrect  Boolean  @default(false)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([questionId, position])
}
